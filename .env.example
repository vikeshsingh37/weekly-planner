# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens. Generate a strong random value in production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Langfuse (local) ─────────────────────────────────────────────────────────
# Start Langfuse: docker compose up -d
# Then open http://localhost:3000, create a project, and paste the keys below.
# If these are not set, tracing is silently disabled — the agent still works.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# ── Langfuse (production, when ready) ────────────────────────────────────────
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com